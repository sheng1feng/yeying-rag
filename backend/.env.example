APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql://knowledge:knowledge@127.0.0.1:5432/knowledge
JWT_SECRET=change-me

WAREHOUSE_GATEWAY_MODE=bound_token
WAREHOUSE_BASE_URL=https://webdav.yeying.pub
WAREHOUSE_WEBDAV_PREFIX=/dav
WAREHOUSE_MOCK_ROOT=../.mock_warehouse
TOKEN_ENCRYPTION_SECRET=

VECTOR_STORE_MODE=db
WEAVIATE_URL=http://127.0.0.1:8080
WEAVIATE_INDEX_NAME=KnowledgeChunk
WEAVIATE_SCHEME=http
WEAVIATE_HOST=127.0.0.1
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=

MODEL_PROVIDER_MODE=mock
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=6
MEMORY_TOP_K=4
WORKER_NAME=knowledge-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_TASK_CONCURRENCY=2
WORKER_MAX_ACTIVE_TASKS_PER_USER=1
WORKER_TASK_HEARTBEAT_INTERVAL_SECONDS=15

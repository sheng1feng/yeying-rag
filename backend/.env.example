APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql://knowledge:knowledge@127.0.0.1:5432/knowledge
JWT_SECRET=change-me

WAREHOUSE_GATEWAY_MODE=bound_token
WAREHOUSE_AUTH_MODE=auto
WAREHOUSE_BASE_URL=https://webdav.yeying.pub
WAREHOUSE_WEBDAV_PREFIX=/dav
WAREHOUSE_SERVICE_BEARER=
WAREHOUSE_FORWARD_WALLET_HEADER=X-End-User-Wallet
WAREHOUSE_MOCK_ROOT=../.mock_warehouse
TOKEN_ENCRYPTION_SECRET=
WAREHOUSE_UCAN_AUDIENCE=did:web:webdav.yeying.pub
WAREHOUSE_UCAN_RESOURCE=profile
WAREHOUSE_UCAN_ACTION=read
WAREHOUSE_UCAN_CHAIN_ID=1
WAREHOUSE_UCAN_SIWE_DOMAIN=knowledge.yeying.pub
WAREHOUSE_UCAN_SIWE_URI=https://knowledge.yeying.pub
WAREHOUSE_UCAN_BOOTSTRAP_TTL_SECONDS=300
WAREHOUSE_UCAN_ROOT_TTL_HOURS=168
WAREHOUSE_UCAN_INVOCATION_TTL_MINUTES=15

VECTOR_STORE_MODE=db
WEAVIATE_URL=http://127.0.0.1:8080
WEAVIATE_INDEX_NAME=KnowledgeChunk
WEAVIATE_ENABLED=true
WEAVIATE_SCHEME=http
WEAVIATE_HOST=127.0.0.1
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=

MODEL_PROVIDER_MODE=mock
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

RERANK_ENABLED=false
RERANK_MODEL=
RERANK_API_BASE=
RERANK_API_KEY=

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=6
MEMORY_TOP_K=4
WORKER_NAME=knowledge-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
